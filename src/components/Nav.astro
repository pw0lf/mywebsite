---
const navLinks = [
  { href: '/',          label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/blog/',     label: 'Blog' },
  { href: '/about/',    label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header" id="nav-header">
  <div class="container nav-inner">
    <!-- Desktop navigation (hidden on mobile) -->
    <nav class="desktop-nav" aria-label="Main navigation">
        <ul class="nav-links">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-link--active': link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    <div class="nav-right">
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
        <!-- Sun (shown in dark mode to switch to light) -->
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon (shown in light mode to switch to dark) -->
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Hamburger (visible only on mobile) -->
      <button id="menu-toggle" class="menu-toggle" aria-label="Open menu" aria-expanded="false">
        <svg class="icon-menu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6"  y1="6" x2="18" y2="18"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile nav panel -->
  <div class="mobile-panel" id="mobile-panel" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['mobile-link', { 'mobile-link--active': link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  /* ── Theme toggle ─────────────────────────────────────── */
  const toggle = document.getElementById('theme-toggle')!;
  const iconSun  = toggle.querySelector('.icon-sun')  as HTMLElement;
  const iconMoon = toggle.querySelector('.icon-moon') as HTMLElement;

  function getTheme() {
    return document.documentElement.getAttribute('data-theme') ?? 'dark';
  }

  function applyTheme(theme: string, animate = false) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    const nextIcon = theme === 'dark' ? iconSun : iconMoon;
    const prevIcon = theme === 'dark' ? iconMoon : iconSun;
    prevIcon.style.display = 'none';
    nextIcon.style.display = 'block';
    if (animate) {
      nextIcon.classList.remove('icon-entering');
      void nextIcon.offsetWidth; // force reflow
      nextIcon.classList.add('icon-entering');
      nextIcon.addEventListener('animationend', () => nextIcon.classList.remove('icon-entering'), { once: true });
    }
  }

  toggle.addEventListener('click', () => {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark', true);
  });

  applyTheme(getTheme());

  /* ── Mobile menu ──────────────────────────────────────── */
  const navHeader   = document.getElementById('nav-header')!;
  const menuToggle  = document.getElementById('menu-toggle')!;
  const mobilePanel = document.getElementById('mobile-panel')!;
  const iconMenu    = menuToggle.querySelector('.icon-menu')  as HTMLElement;
  const iconClose   = menuToggle.querySelector('.icon-close') as HTMLElement;

  function openMenu() {
    navHeader.classList.add('is-open');
    mobilePanel.setAttribute('aria-hidden', 'false');
    menuToggle.setAttribute('aria-expanded', 'true');
    menuToggle.setAttribute('aria-label', 'Close menu');
    iconMenu.style.display  = 'none';
    iconClose.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navHeader.classList.remove('is-open');
    mobilePanel.setAttribute('aria-hidden', 'true');
    menuToggle.setAttribute('aria-expanded', 'false');
    menuToggle.setAttribute('aria-label', 'Open menu');
    iconMenu.style.display  = 'block';
    iconClose.style.display = 'none';
    document.body.style.overflow = '';
  }

  menuToggle.addEventListener('click', () => {
    navHeader.classList.contains('is-open') ? closeMenu() : openMenu();
  });

  // Close when a link is clicked
  mobilePanel.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 640) closeMenu();
  });
</script>

<style>
  .nav-header {
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-nav);
    backdrop-filter: blur(12px);
    transition: background 250ms ease, border-color 250ms ease;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .desktop-nav {
    flex: 1;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }

  /* ── Desktop nav ──────────────────────────────────────── */
  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    transition: color var(--transition);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 240ms var(--ease-out);
  }

  .nav-link:hover {
    color: var(--fg);
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    transform: scaleX(1);
  }

  .nav-link--active {
    color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link::after { transition: none; }
  }

  /* ── Theme toggle ─────────────────────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--bg-subtle);
    border: 1px solid var(--fg-muted);
    color: var(--fg);
    cursor: pointer;
    border-radius: 4px;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .icon-sun, .icon-moon { display: none; }

  @keyframes iconEnter {
    from { opacity: 0; transform: rotate(-50deg) scale(0.65); }
    to   { opacity: 1; transform: rotate(0deg)   scale(1); }
  }

  .icon-entering {
    animation: iconEnter 260ms var(--ease-out) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .icon-entering { animation: none; }
  }

  /* ── Hamburger button ─────────────────────────────────── */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--bg-subtle);
    border: 1px solid var(--fg-muted);
    color: var(--fg);
    cursor: pointer;
    border-radius: 4px;
    transition: color var(--transition), border-color var(--transition);
    flex-shrink: 0;
  }

  .menu-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── Mobile panel ─────────────────────────────────────── */
  .mobile-panel {
    display: none;
    overflow: hidden;
    border-top: 1px solid var(--border);
    background: var(--bg-nav);
  }

  .mobile-links {
    list-style: none;
    padding-inline: var(--container-px);
  }

  .mobile-link {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    padding-block: 1rem;
    border-bottom: 1px solid var(--border);
    transition: color var(--transition);
  }

  .mobile-links li:last-child .mobile-link {
    border-bottom: none;
  }

  .mobile-link:hover,
  .mobile-link--active {
    color: var(--accent);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 639px) {
    .desktop-nav {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }

    .mobile-panel {
      display: block;
      max-height: 0;
      border-top: none;
      transition: max-height 280ms cubic-bezier(0.16, 1, 0.3, 1),
                  border-top 0ms 280ms;
    }

    .nav-header.is-open .mobile-panel {
      max-height: 300px;
      border-top: 1px solid var(--border);
      transition: max-height 280ms cubic-bezier(0.16, 1, 0.3, 1);
    }
  }

  @media (min-width: 640px) {
    .nav-right {
      gap: 2rem;
    }

    .mobile-panel {
      display: none !important;
    }
  }
</style>
