---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <div id="reading-progress" aria-hidden="true"></div>
  <article class="post-wrapper">

    <div class="header-container">
      <a href="/blog/" class="back-link animate" style="--delay: 0ms">← All Posts</a>
      <div class="post-meta animate" style="--delay: 40ms">
        <time datetime={post.data.pubDate.toISOString()} class="post-date">
          {formatDate(post.data.pubDate)}
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="tag-row">
            {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
      <h1 class="post-title animate" style="--delay: 80ms">{post.data.title}</h1>
      <p class="post-description animate" style="--delay: 120ms">{post.data.description}</p>
    </div>

    <div class="divider"></div>

    <div class="prose-container">
      <div class="prose animate" style="--delay: 160ms">
        <Content />
      </div>
    </div>

  </article>
</BaseLayout>

<style>
  .post-wrapper {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .header-container,
  .prose-container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  /* Narrower reading column */
  .header-container > *,
  .prose {
    max-width: 46rem;
  }

  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--accent);
    z-index: 200;
    pointer-events: none;
    transition: width 60ms linear;
    will-change: width;
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2.5rem;
    transition: color var(--transition), transform 220ms var(--ease-out);
  }

  .back-link:hover {
    color: var(--accent);
    transform: translateX(-4px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .post-date {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.2em 0.65em;
  }

  .post-title {
    font-size: var(--text-4xl);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .post-description {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .divider {
    border-top: 1px solid var(--border);
    margin-block: 3rem;
  }

  /* ── Prose ────────────────────────────────────────────── */
  .prose {
    font-size: var(--text-base);
    line-height: 1.82;
    color: var(--fg);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--fg);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--fg);
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: oklch(64% 0.11 196 / 0.35);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--transition);
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding: 0.25rem 0 0.25rem 1.5rem;
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 300;
    font-style: italic;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  .prose :global(code) {
    font-size: 0.87em;
    background: var(--bg-subtle);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }

  .prose :global(pre) {
    background: var(--bg-subtle);
    color: var(--fg);
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875em;
    line-height: 1.72;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 3rem;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--fg);
  }

  .prose :global(em) {
    font-style: italic;
  }
</style>

<script>
  const bar = document.getElementById('reading-progress') as HTMLElement;
  const prose = document.querySelector('.prose') as HTMLElement;

  function updateProgress() {
    if (!prose || !bar) return;
    const proseTop = prose.getBoundingClientRect().top + window.scrollY;
    const proseBottom = proseTop + prose.offsetHeight;
    const viewH = window.innerHeight;
    const start = proseTop - viewH;
    const total = proseBottom - viewH - start;
    const pct = Math.min(Math.max((window.scrollY - start) / total, 0), 1);
    bar.style.width = (pct * 100).toFixed(1) + '%';
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>
