---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Philipp Wolf — Mathematics & Computer Science student.">
  <div class="container">

    <h1 class="about-title animate" style="--delay: 80ms">
      Hello,<br /><em>I'm Philipp.</em>
    </h1>

    <div class="about-body animate" style="--delay: 160ms">
      <p>
        t.b.d.
      </p>
    </div>

    <h2 class="section-heading animate" style="--delay: 200ms">Education</h2>

    <div class="cv-section animate" style="--delay: 240ms">
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2020 – 2024</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">B.Sc. Placeholder Degree</p>
          <p class="cv-sub">Placeholder University</p>
        </div>
      </div>
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2024 – present</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">M.Sc. Placeholder Degree</p>
          <p class="cv-sub">Placeholder University</p>
        </div>
      </div>
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2018 – 2020</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">Placeholder Certificate / Exchange</p>
          <p class="cv-sub">Placeholder Institution</p>
        </div>
      </div>
    </div>

    <h2 class="section-heading animate" style="--delay: 280ms">Work Experience</h2>

    <div class="cv-section animate" style="--delay: 320ms">
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2023 – 2024</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">Placeholder Job Title</p>
          <p class="cv-sub">Placeholder Company — Full-time</p>
        </div>
      </div>
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2022</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">Placeholder Internship</p>
          <p class="cv-sub">Placeholder Company — Internship</p>
        </div>
      </div>
      <div class="cv-item">
        <div class="cv-meta">
          <span class="cv-year">2021</span>
        </div>
        <div class="cv-body">
          <p class="cv-title">Placeholder Research Assistant</p>
          <p class="cv-sub">Placeholder Lab / Institute</p>
        </div>
      </div>
    </div>

    <h2 class="section-heading animate" style="--delay: 360ms">Get in touch</h2>

    <div class="about-body animate" style="--delay: 400ms">
      <p>
        Feel free to reach out:<br/>
        <a id="email-link" class="email-link" href="#">loading…</a>
      </p>
      <div class="social-links">
        <a href="https://github.com/pw0lf" class="social-btn" target="_blank" rel="noopener noreferrer">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/wolfphilipp99/" class="social-btn" target="_blank" rel="noopener noreferrer">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .container {
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
    max-width: 56ch;
  }

  .about-title {
    font-size: var(--text-4xl);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 2.5rem;
  }

  .about-title em {
    font-style: italic;
    color: var(--accent);
  }

  .about-body p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 0.875rem;
    color: var(--fg);
  }

  /* ── CV timeline ────────────────────────────────────────── */
  .cv-section {
    margin-bottom: 0.5rem;
  }

  .cv-item {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding-block: 1rem;
    border-top: 1px solid var(--border);
  }

  .cv-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .cv-year {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    padding-top: 0.2rem;
  }

  .cv-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    margin: 0 0 0.2rem;
    line-height: 1.4;
  }

  .cv-sub {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.4;
  }

  /* ── Social buttons ─────────────────────────────────────── */
  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    padding: 0.5em 1em;
    border-radius: 4px;
    transition: color var(--transition), border-color var(--transition);
  }

  .social-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .email-link {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .email-link:hover {
    color: var(--accent);
  }
</style>

<script>
  const u = 'philippwolf99';
  const d = 'icloud';
  const t = 'com';
  const addr = u + '@' + d + '.' + t;
  const el = document.getElementById('email-link') as HTMLAnchorElement;
  if (el) {
    el.textContent = addr;
    el.href = 'mailto:' + addr;
  }
</script>
