---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const featuredProjects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 2);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="Home" description="Philipp Wolf — developer, builder, writer.">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">

      <div class="hero-visual animate" style="--delay: 0ms" aria-hidden="true">
        <canvas id="neuralCanvas"></canvas>
      </div>

      <div class="hero-text">
        <p class="hero-eyebrow animate" style="--delay: 60ms">Mathematics &amp; Computer Science Student</p>
        <h1 class="hero-name animate" style="--delay: 120ms">
          Philipp<br /><em>Wolf</em>
        </h1>
        <p class="hero-bio animate" style="--delay: 220ms">
          I have a broad interest in computer science and mathematics, and enjoy exploring various topics across both fields.
          My current focus is on topological deep learning - bringing tools from algebraic topology into modern neural network architectures. 
          I have also worked on and published research on fairness in AI and machine learning.
        </p>
        <div class="hero-links animate" style="--delay: 300ms">
          <a href="https://github.com/pw0lf" class="social-btn" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/wolfphilipp99/" class="social-btn" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Selected Projects -->
  <section class="section">
    <div class="container">
      <div class="section-header animate" style="--delay: 260ms">
        <span class="section-label">Selected Work</span>
        <a href="/projects/" class="section-link">All projects →</a>
      </div>
      <div class="project-grid">
        {featuredProjects.map((project, i) => (
          <a href={`/projects/${project.slug}/`} class="project-card animate" style={`--delay: ${320 + i * 80}ms`}>
            <div class="card-thumb" data-index={i}>
              {project.data.thumbnail
                ? <img src={project.data.thumbnail} alt={project.data.title} />
                : <div class="thumb-placeholder">
                    <span class="thumb-num">{String(i + 1).padStart(2, '0')}</span>
                  </div>
              }
            </div>
            <div class="card-body">
              <div class="card-meta">
                <div class="tag-row">
                  {project.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <h3 class="card-title">{project.data.title}</h3>
              <p class="card-desc">{project.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Writing -->
  <section class="section">
    <div class="container">
      <div class="section-header animate" style="--delay: 300ms">
        <span class="section-label">Recent Writing</span>
        <a href="/blog/" class="section-link">All posts →</a>
      </div>
      <div class="post-list">
        {posts.map((post, i) => (
          <article class="post-item animate" style={`--delay: ${360 + i * 60}ms`}>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <div class="post-content">
              <h3 class="post-title">
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="post-desc">{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const canvas = document.getElementById('neuralCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const ACCENT_DARK  = [232, 197, 71]  as const;
  const ACCENT_LIGHT = [60, 80, 170] as const;
  function getAccent() {
    return document.documentElement.getAttribute('data-theme') === 'light'
      ? ACCENT_LIGHT : ACCENT_DARK;
  }
  const NUM_NODES = 18;
  const CONNECT_DIST = 160;

  interface Node {
    x: number; y: number;
    vx: number; vy: number;
    r: number; phase: number;
  }

  interface Signal {
    from: number; to: number;
    t: number; speed: number;
  }

  let nodes: Node[] = [];
  let signals: Signal[] = [];
  let w = 0, h = 0;
  let mouse = { x: -9999, y: -9999 };

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    w = rect.width;
    h = rect.height;
    canvas.width = w * devicePixelRatio;
    canvas.height = h * devicePixelRatio;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function initNodes() {
    nodes = [];
    for (let i = 0; i < NUM_NODES; i++) {
      const r = Math.random() * 3 + 4;
      const margin = (r + 2) * 2.8; // full glow radius
      nodes.push({
        x: margin + Math.random() * (w - 2 * margin),
        y: margin + Math.random() * (h - 2 * margin),
        vx: (Math.random() - 0.5) * 0.25,
        vy: (Math.random() - 0.5) * 0.25,
        r,
        phase: Math.random() * Math.PI * 2,
      });
    }
  }

  function spawnSignal() {
    const a = Math.floor(Math.random() * nodes.length);
    const b = Math.floor(Math.random() * nodes.length);
    if (a === b) return;
    const dx = nodes[b].x - nodes[a].x;
    const dy = nodes[b].y - nodes[a].y;
    if (Math.sqrt(dx * dx + dy * dy) > CONNECT_DIST) return;
    signals.push({ from: a, to: b, t: 0, speed: 0.007 + Math.random() * 0.006 });
  }

  function draw(time: number) {
    ctx.clearRect(0, 0, w, h);
    const t = time / 1000;
    const [r, g, b] = getAccent();

    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[j].x - nodes[i].x;
        const dy = nodes[j].y - nodes[i].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.45;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
          ctx.lineWidth = 1.2;
          ctx.stroke();
        }
      }
    }

    for (let i = signals.length - 1; i >= 0; i--) {
      const s = signals[i];
      s.t += s.speed;
      if (s.t >= 1) { signals.splice(i, 1); continue; }
      const fn = nodes[s.from];
      const tn = nodes[s.to];
      const sx = fn.x + (tn.x - fn.x) * s.t;
      const sy = fn.y + (tn.y - fn.y) * s.t;
      const grd = ctx.createRadialGradient(sx, sy, 0, sx, sy, 14);
      grd.addColorStop(0, `rgba(${r},${g},${b},1)`);
      grd.addColorStop(0.35, `rgba(${r},${g},${b},0.5)`);
      grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.beginPath();
      ctx.arc(sx, sy, 14, 0, Math.PI * 2);
      ctx.fillStyle = grd;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(sx, sy, 3.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},1)`;
      ctx.fill();
    }

    for (const node of nodes) {
      node.x += node.vx;
      node.y += node.vy;
      const margin = (node.r + 2) * 2.8; // full glow radius
      if (node.x < margin || node.x > w - margin) node.vx *= -1;
      if (node.y < margin || node.y > h - margin) node.vy *= -1;
      node.x = Math.max(margin, Math.min(w - margin, node.x));
      node.y = Math.max(margin, Math.min(h - margin, node.y));

      // Mouse repulsion — nodes scatter gently from cursor
      const mdx = node.x - mouse.x;
      const mdy = node.y - mouse.y;
      const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
      if (mdist < 140 && mdist > 0) {
        const force = (1 - mdist / 140) * 0.014;
        node.vx += (mdx / mdist) * force;
        node.vy += (mdy / mdist) * force;
        const spd = Math.sqrt(node.vx * node.vx + node.vy * node.vy);
        if (spd > 1.0) { node.vx = node.vx / spd; node.vy = node.vy / spd; }
      } else {
        // Gradually settle back to natural pace when mouse is away
        const spd = Math.sqrt(node.vx * node.vx + node.vy * node.vy);
        if (spd > 0.4) { node.vx *= 0.99; node.vy *= 0.99; }
      }

      const pulse = Math.sin(t * 1.8 + node.phase) * 0.5 + 0.5;
      const radius = node.r + pulse * 2;
      const alpha = 0.55 + pulse * 0.3;

      const grd = ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, radius * 2.8);
      grd.addColorStop(0, `rgba(${r},${g},${b},${alpha * 0.45})`);
      grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.beginPath();
      ctx.arc(node.x, node.y, radius * 2.8, 0, Math.PI * 2);
      ctx.fillStyle = grd;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(node.x, node.y, radius, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(node.x, node.y, radius * 0.45, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
      ctx.fill();
    }
  }

  function loop(time: number) {
    draw(time);
    requestAnimationFrame(loop);
  }

  resize();
  initNodes();
  requestAnimationFrame(loop);
  setInterval(() => { if (signals.length < 6) spawnSignal(); }, 280);

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { resize(); initNodes(); }, 150);
  });
</script>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .hero {
    padding-top: clamp(4rem, 10vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
    }
  }

  .hero-visual {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-height: 420px;
    order: 2;
  }

  @media (min-width: 768px) {
    .hero-visual { order: 0; max-height: none; }
  }

  #neuralCanvas { display: block; width: 100%; height: 100%; }

  .hero-text { display: flex; flex-direction: column; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin-bottom: 2rem;
  }

  .hero-name {
    font-size: var(--text-4xl);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.035em;
    margin-bottom: 2rem;
  }

  .hero-name em { font-style: italic; color: var(--accent); }

  .hero-bio {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--fg-muted);
    max-width: 48ch;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    padding: 0.5em 1em;
    border-radius: 4px;
    transition: color var(--transition), border-color var(--transition);
  }

  .social-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── Sections ──────────────────────────────────────────── */
  .section {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border);
  }

  .section:last-child { border-bottom: none; }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.875rem;
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent);
    transition: opacity var(--transition), transform 220ms var(--ease-out);
  }

  .section-link:hover {
    opacity: 0.85;
    transform: translateX(4px);
  }

  /* ── Project cards ─────────────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color var(--transition), transform var(--transition);
    text-decoration: none;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  /* Thumbnail */
  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
    box-sizing: border-box;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Different gradient per card using data-index */
  .card-thumb[data-index="0"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 12%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 4%, var(--bg)) 100%);
  }

  .card-thumb[data-index="1"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 8%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 18%, var(--bg)) 100%);
  }

  .thumb-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 300;
    font-style: italic;
    color: color-mix(in oklch, var(--accent) 30%, transparent);
    line-height: 1;
    user-select: none;
  }

  /* Card body */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    border: 1px solid color-mix(in oklch, var(--accent) 40%, transparent);
    padding: 0.15em 0.55em;
    border-radius: 2px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--fg);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.6;
  }

  /* ── Blog posts ────────────────────────────────────────── */
  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding-block: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .post-item:last-child { border-bottom: none; padding-bottom: 0; }

  @media (min-width: 640px) {
    .post-item {
      grid-template-columns: 10rem 1fr;
      gap: 2rem;
      align-items: baseline;
    }
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
  }

  .post-title a { transition: color var(--transition); }
  .post-title a:hover { color: var(--accent); }

  .post-desc {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.55;
  }
</style>
