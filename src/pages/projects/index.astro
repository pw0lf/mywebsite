---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Projects" description="Selected projects and work by Philipp Wolf.">
  <div class="container">

    <header class="page-header animate" style="--delay: 0ms">
      <p class="page-eyebrow">Selected Work</p>
      <h1 class="page-title">Projects</h1>
    </header>

    <div class="project-grid">
      {projects.map((project, i) => (
        <a href={`/projects/${project.slug}/`} class="project-card animate" style={`--delay: ${80 + i * 60}ms`}>
          <div class="card-thumb" data-index={i % 4}>
            {project.data.thumbnail
              ? <img src={project.data.thumbnail} alt={project.data.title} />
              : <div class="thumb-placeholder">
                  <span class="thumb-num">{String(i + 1).padStart(2, '0')}</span>
                </div>
            }
          </div>
          <div class="card-body">
            <div class="card-meta">
              <div class="tag-row">
                {project.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <h2 class="card-title">{project.data.title}</h2>
            <p class="card-desc">{project.data.description}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .container {
    padding-top: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .page-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 3rem;
    margin-bottom: 3rem;
  }

  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: var(--text-4xl);
    font-weight: 300;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--fg-muted);
    max-width: 50ch;
  }

  /* ── Grid ──────────────────────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 520px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .project-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card ──────────────────────────────────────────────── */
  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color var(--transition), transform var(--transition);
    text-decoration: none;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 1rem;
    box-sizing: border-box;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-thumb[data-index="0"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 12%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 4%, var(--bg)) 100%);
  }
  .card-thumb[data-index="1"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 5%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 16%, var(--bg)) 100%);
  }
  .card-thumb[data-index="2"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 14%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 6%, var(--bg)) 100%);
  }
  .card-thumb[data-index="3"] .thumb-placeholder {
    background: linear-gradient(135deg,
      color-mix(in oklch, var(--accent) 7%, var(--bg)) 0%,
      color-mix(in oklch, var(--accent) 13%, var(--bg)) 100%);
  }

  .thumb-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    font-style: italic;
    color: color-mix(in oklch, var(--accent) 28%, transparent);
    line-height: 1;
    user-select: none;
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    border: 1px solid color-mix(in oklch, var(--accent) 40%, transparent);
    padding: 0.15em 0.55em;
    border-radius: 2px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--fg);
    transition: color var(--transition);
  }

  .project-card:hover .card-title { color: var(--accent); }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.6;
  }
</style>
